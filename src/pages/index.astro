---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import Hr from "@/components/Hr.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";
import { SOCIALS } from "@/constants";

const posts = await getCollection("blog");

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index">
    <section id="hero" class="pt-6 pb-4">
      <div class="flex flex-col items-start gap-4 sm:flex-row">
        <a href="/about" class="group mx-auto block sm:mx-0">
          <img
            src="/images/ryan-headshot.jpeg"
            alt="Ryan Wallace"
            class="h-40 w-40 flex-shrink-0 rounded-full object-cover transition-all duration-300 group-hover:scale-105 group-hover:shadow-xl"
          />
        </a>
        <div class="flex-1 text-center sm:text-left">
          <div class="flex items-center justify-center gap-2 sm:justify-start">
            <h1
              class="my-2 inline-block text-2xl font-bold sm:my-4 sm:text-3xl"
            >
              Hi, I'm <span class="text-accent">@ryancswallace</span>.
            </h1>
            <a
              target="_blank"
              href="/rss.xml"
              class="inline-block"
              aria-label="rss feed"
              title="RSS Feed"
            >
              <IconRss
                width={20}
                height={20}
                class="scale-125 stroke-accent stroke-3"
              />
              <span class="sr-only">RSS Feed</span>
            </a>
          </div>
          <p>
            I work on data systems, research infrastructure, and AI/ML in
            economics. This is where I collect projects, technical notes, and
            things I'm learning.
          </p>
          <br />
          <p>
            Resume:
            <a
              target="_blank"
              download
              href="https://ryancswallace.github.io/resume/resume_ryan-wallace.pdf"
              class="break-words text-foreground underline decoration-dashed underline-offset-4 hover:text-accent focus-visible:no-underline"
              aria-label="PDF resume"
              title="PDF Resume"
            >
              PDF</a
            >
            |
            <a
              target="_blank"
              download
              href="https://ryancswallace.github.io/resume/resume_ryan-wallace.rtf"
              class="break-words text-foreground underline decoration-dashed underline-offset-4 hover:text-accent focus-visible:no-underline"
              aria-label="RTF resume"
              title="RTF Resume"
            >
              RTF</a
            >
            |
            <a
              target="_blank"
              download
              href="https://ryancswallace.github.io/resume/resume_ryan-wallace.md"
              class="break-words text-foreground underline decoration-dashed underline-offset-4 hover:text-accent focus-visible:no-underline"
              aria-label="Markdown resume"
              title="Markdown Resume"
            >
              Markdown</a
            >
            |
            <a
              target="_blank"
              download
              href="https://ryancswallace.github.io/resume/resume_ryan-wallace.tex"
              class="break-words text-foreground underline decoration-dashed underline-offset-4 hover:text-accent focus-visible:no-underline"
              aria-label="TeX resume"
              title="TeX Resume"
            >
              TeX</a
            >
          </p>
          {
            // only display if at least one social link is enabled
            SOCIALS.length > 0 && (
              <div class="mt-4 flex flex-row items-center justify-center sm:justify-start">
                <Socials />
              </div>
            )
          }
        </div>
      </div>
    </section>

    <Hr />

    {
      featuredPosts.length > 0 && (
        <>
          <section id="featured" class="pt-12 pb-6">
            <h2 class="text-2xl font-semibold tracking-wide">Featured</h2>
            <ul>
              {featuredPosts.map(data => (
                <Card variant="h3" {...data} />
              ))}
            </ul>
          </section>
          {recentPosts.length > 0 && <Hr />}
        </>
      )
    }

    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="pt-12 pb-6">
          <h2 class="text-2xl font-semibold tracking-wide">Recent Posts</h2>
          <ul>
            {recentPosts.map(
              (data, index) =>
                index < SITE.postPerIndex && <Card variant="h3" {...data} />
            )}
          </ul>
        </section>
      )
    }

    <div class="my-8 text-center">
      <LinkButton href="/posts/">
        All Posts
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
